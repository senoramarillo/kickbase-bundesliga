---
import favIcon from '../../../images/favicon-16.png';
import { BASE_PATH_WITHOUT_DOMAIN } from '../../../base-path.mjs';
import { matchdaysService, MatchdayOverview } from '../../services/matchdays.service';
import '../../components/matchdays.page.ts';
import '../../styles/page.css';
import { MatchdaysPage } from '../../components/matchdays.page.ts';

const matchdayOverview: MatchdayOverview = await matchdaysService.getData();
const props: Record<string, string> = {
  'server-json-data': JSON.stringify(matchdayOverview),
  'team-base-path': `${BASE_PATH_WITHOUT_DOMAIN}/bundesliga/team`
};
const currentMatchday: number = matchdayOverview.currentMatchday;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={favIcon} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-700.woff2`} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-regular.woff2`} />
    <title>Bundesliga Spieltag</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="kickbase-bundesliga Spieltagsübersicht mit Partien und Ergebnissen" />
  </head>
  <body style="background-color: #e8edf1; padding: 1rem;">
    <MatchdaysPage {...props} />
    <script define:vars={{ currentMatchday }}>
      const scrollToCurrentMatchday = () => {
        if ('scrollRestoration' in window.history) {
          window.history.scrollRestoration = 'manual';
        }

        const matchdaysElement = document.querySelector('bkb-matchdays');
        const matchdaysRoot = matchdaysElement?.shadowRoot ?? matchdaysElement;
        const currentMatchdaySection = matchdaysRoot?.querySelector('.current-matchday-section');

        if (!currentMatchdaySection) {
          return false;
        }

        const behavior = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth';
        const scrollTop = currentMatchdaySection.getBoundingClientRect().top + window.scrollY - 16;
        window.scrollTo({ top: Math.max(scrollTop, 0), behavior });
        return true;
      };

      const scheduleCurrentMatchdayScroll = () => {
        [0, 150, 500, 1000, 1800].forEach(delay => {
          window.setTimeout(scrollToCurrentMatchday, delay);
        });
      };

      window.addEventListener('load', scheduleCurrentMatchdayScroll, { once: true });
      customElements.whenDefined('bkb-matchdays').then(scheduleCurrentMatchdayScroll).catch(() => {});
      scheduleCurrentMatchdayScroll();
    </script>
  </body>
</html>
