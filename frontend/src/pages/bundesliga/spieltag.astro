---
import favIcon from '../../../images/favicon-16.png';
import { BASE_PATH_WITHOUT_DOMAIN } from '../../../base-path.mjs';
import { COMPETITIONS } from '../../models/competition';
import CompetitionSwitcher from '../../components/competition-switcher.astro';
import { matchdaysService, MatchdayOverview } from '../../services/matchdays.service';
import '../../components/matchdays.page.ts';
import '../../styles/page.css';
import { MatchdaysPage } from '../../components/matchdays.page.ts';

const competition = COMPETITIONS.bundesliga;
const matchdayOverview: MatchdayOverview = await matchdaysService.getData(competition.competitionId);
const props: Record<string, string> = {
  'server-json-data': JSON.stringify(matchdayOverview),
  'player-base-path': `${BASE_PATH_WITHOUT_DOMAIN}/bundesliga/player`,
  'team-base-path': `${BASE_PATH_WITHOUT_DOMAIN}/bundesliga/team`
};
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={favIcon} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-700.woff2`} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-regular.woff2`} />
    <title>{competition.label} Spieltage</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`kickbase-bundesliga ${competition.label} Spieltagsübersicht mit Partien und Ergebnissen`} />
  </head>
  <body style="background-color: #e8edf1; padding: 1rem;">
    <CompetitionSwitcher currentSlug="bundesliga" section="spieltag" />
    <MatchdaysPage {...props} client:idle />
  </body>
</html>
