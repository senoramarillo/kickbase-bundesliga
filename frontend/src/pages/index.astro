---
import favIcon from '../../images/favicon-16.png';
import { BASE_PATH_WITHOUT_DOMAIN, KICKBASE_API_CONFIG } from '../../base-path.mjs';
import { teamPlayerService } from '../services/team-players.service';
import { bundesligaTableService } from '../services/bundesliga-table.service';
import { BundesligaTableEntry, BundesligaTable } from '../models/bundesliga-table';
import { PlayerListItem } from '../models/player-list-item';
import { getPlayerPositionLabel, PlayerPosition } from '../models/player-position';
import { COMPETITIONS, type CompetitionConfig } from '../models/competition';
import { teamLogosLarge } from '../../images/teams/large';

interface CompetitionSection {
  slug: CompetitionConfig['slug'];
  label: string;
  shortLabel: string;
  teamBasePath: string;
  playerBasePath: string;
  teamLogosByName: Record<string, string>;
  groupedTeams: [string, PlayerListItem[]][];
  playerCount: number;
}

async function buildCompetitionSection(competition: CompetitionConfig): Promise<CompetitionSection> {
  const table: BundesligaTable = await bundesligaTableService.getData(competition.competitionId);
  const teamIds: string[] = table.teams.map((team: BundesligaTableEntry) => team.teamId);

  const deepPlayerData: PlayerListItem[][] = [];
  for (const teamId of teamIds) {
    deepPlayerData.push(await teamPlayerService.getData(teamId, competition.competitionId));
  }

  const playerData: PlayerListItem[] = deepPlayerData.flat();
  const playersGroupedByTeam: Record<string, PlayerListItem[]> = {};

  playerData.forEach((player: PlayerListItem) => {
    if (playersGroupedByTeam[player.teamName]) {
      playersGroupedByTeam[player.teamName].push(player);
    } else {
      playersGroupedByTeam[player.teamName] = [player];
    }
  });

  return {
    slug: competition.slug,
    label: competition.label,
    shortLabel: competition.shortLabel,
    teamBasePath: `${BASE_PATH_WITHOUT_DOMAIN}/${competition.slug}/team`,
    playerBasePath: `${BASE_PATH_WITHOUT_DOMAIN}/${competition.slug}/player`,
    teamLogosByName: Object.fromEntries(
      table.teams.map((team: BundesligaTableEntry) => [
        team.teamName,
        teamLogosLarge[`team_${team.teamId}`] ??
          (team.teamLogo
            ? team.teamLogo.startsWith('http')
              ? team.teamLogo
              : `${KICKBASE_API_CONFIG.CDN_URL}${team.teamLogo}`
            : '')
      ])
    ),
    groupedTeams: Object.entries(playersGroupedByTeam).sort(([leftTeam], [rightTeam]) => leftTeam.localeCompare(rightTeam)),
    playerCount: playerData.length
  };
}

const competitionSections: CompetitionSection[] = await Promise.all([
  buildCompetitionSection(COMPETITIONS.bundesliga),
  buildCompetitionSection(COMPETITIONS['zweite-bundesliga'])
]);

function sortPlayers(players: PlayerListItem[]): PlayerListItem[] {
  return [...players].sort((left: PlayerListItem, right: PlayerListItem) => {
    if (left.position !== right.position) {
      return left.position - right.position;
    }

    if ((left.number ?? 0) !== (right.number ?? 0)) {
      return (left.number ?? 0) - (right.number ?? 0);
    }

    return left.playerName.localeCompare(right.playerName);
  });
}

const playerCategories: { label: string; position: PlayerPosition }[] = [
  { label: 'Torwart', position: PlayerPosition.GOAL_KEEPER },
  { label: 'Abwehr', position: PlayerPosition.DEFENDER },
  { label: 'Mittelfeld', position: PlayerPosition.MIDFIELDER },
  { label: 'Sturm', position: PlayerPosition.FORWARD }
];

const playerSearchData = competitionSections.flatMap(section =>
  section.groupedTeams.flatMap(([, players]) =>
    players.map((player: PlayerListItem) => ({
      playerId: player.playerId,
      playerName: player.playerName,
      teamName: player.teamName,
      number: player.number,
      competitionLabel: section.shortLabel,
      playerBasePath: section.playerBasePath,
      positionLabel: getPlayerPositionLabel(player.position as unknown as PlayerPosition)
    }))
  )
);
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={favIcon} />
    <title>kickbase-bundesliga</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="kickbase-bundesliga Startseite" />
    <style>
      :root {
        --page-bg: #e8edf1;
        --panel-bg: #ffffff;
        --panel-border: #d7dee3;
        --text-main: #132128;
        --text-muted: #63727a;
        --accent: #1d5f7a;
        --accent-soft: #dcecf4;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 1.5rem;
        background: radial-gradient(circle at top left, #f5f8fa 0%, var(--page-bg) 55%);
        color: var(--text-main);
        font-family: 'Roboto Condensed', sans-serif;
      }

      main {
        max-width: 1280px;
        margin: 0 auto;
      }

      .hero {
        background: linear-gradient(135deg, #ffffff 0%, #f1f6f8 100%);
        border: 1px solid var(--panel-border);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: 0 18px 50px rgba(19, 33, 40, 0.08);
      }

      .eyebrow {
        margin: 0 0 0.35rem;
        color: var(--accent);
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1;
      }

      .hero-copy {
        max-width: none;
        margin: 0.75rem 0 0;
        color: var(--text-muted);
        font-size: 1rem;
        white-space: normal;
        overflow-wrap: anywhere;
      }

      .quick-links {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.75rem;
        margin-top: 1.5rem;
      }

      .league-switcher {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1.25rem;
      }

      .league-switch-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.4rem;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid #cfd9de;
        background: rgba(255, 255, 255, 0.86);
        color: var(--text-main);
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .league-switch-button.active {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }

      .search-panel {
        margin-top: 1rem;
        padding: 1rem 1.1rem;
        background: rgba(255, 255, 255, 0.75);
        border: 1px solid var(--panel-border);
        border-radius: 0.85rem;
      }

      .search-label {
        display: block;
        margin-bottom: 0.45rem;
        color: var(--text-muted);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .search-input {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 1px solid #c8d5dc;
        border-radius: 0.8rem;
        font: inherit;
        font-size: 1rem;
        color: var(--text-main);
        background: #fff;
      }

      .search-input:focus {
        outline: 2px solid rgba(29, 95, 122, 0.14);
        border-color: var(--accent);
      }

      .search-results {
        display: none;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.65rem;
        margin-top: 0.85rem;
      }

      .search-results.active {
        display: grid;
      }

      .search-result {
        display: block;
        padding: 0.8rem 0.9rem;
        background: #fff;
        border: 1px solid var(--panel-border);
        border-radius: 0.8rem;
        color: inherit;
        text-decoration: none;
      }

      .search-result:hover {
        border-color: #b9cad2;
        box-shadow: 0 10px 20px rgba(19, 33, 40, 0.06);
      }

      .search-result-name {
        font-weight: 700;
      }

      .search-result-line {
        display: block;
      }

      .search-result-meta {
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .search-empty {
        display: none;
        margin-top: 0.75rem;
        color: var(--text-muted);
      }

      .search-empty.active {
        display: block;
      }

      .quick-link {
        display: block;
        padding: 1rem 1.1rem;
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: 0.85rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
      }

      .quick-link:hover {
        transform: translateY(-2px);
        border-color: #b9cad2;
        box-shadow: 0 12px 24px rgba(19, 33, 40, 0.08);
      }

      .quick-link-title {
        display: block;
        font-size: 1.15rem;
        font-weight: 700;
      }

      .quick-link-copy {
        display: block;
        margin-top: 0.35rem;
        color: var(--text-muted);
      }

      .teams {
        margin-top: 2rem;
      }

      .competition-panel {
        display: none;
      }

      .competition-panel.active {
        display: block;
      }

      .teams-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .teams-header h2 {
        margin: 0;
        font-size: 1.6rem;
      }

      .teams-header p {
        margin: 0;
        color: var(--text-muted);
      }

      .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
      }

      .team-card {
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: 1rem;
        padding: 1rem;
        box-shadow: 0 12px 30px rgba(19, 33, 40, 0.05);
      }

      .team-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
        flex-wrap: nowrap;
      }

      .team-card-header-main {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex: 1 1 auto;
        min-width: 0;
      }

      .team-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        padding: 0.35rem;
        background: #fff;
        border: 1px solid #e3eaee;
        border-radius: 0.85rem;
        overflow: hidden;
        flex: 0 0 auto;
      }

      .team-logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transform: scale(1.08);
        transform-origin: center;
      }

      .team-card-title {
        margin: 0;
        font-size: 1.08rem;
        line-height: 1.2;
        word-break: normal;
        overflow-wrap: normal;
        hyphens: auto;
      }

      .player-count {
        color: var(--text-muted);
        font-size: 0.9rem;
        flex: 0 0 auto;
        white-space: nowrap;
      }

      .player-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .position-groups {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }

      .position-group-title {
        margin: 0 0 0.45rem;
        color: var(--text-muted);
        font-size: 0.82rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .player-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        min-height: 2rem;
        padding: 0.4rem 0.7rem;
        background: var(--accent-soft);
        border-radius: 999px;
        text-decoration: none;
        color: var(--text-main);
        font-size: 0.95rem;
      }

      .player-link:hover {
        background: #cfe3ee;
      }

      .player-meta {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--text-muted);
        font-size: 0.82rem;
      }

      .player-number,
      .player-position {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.6rem;
        min-height: 1.35rem;
        padding: 0 0.35rem;
        background: rgba(19, 33, 40, 0.08);
        border-radius: 999px;
      }

      @media (max-width: 640px) {
        body {
          padding: 1rem;
        }

        .hero {
          padding: 1.1rem;
        }

        .quick-links,
        .search-results,
        .team-grid {
          grid-template-columns: 1fr;
        }

        .teams-header {
          align-items: center;
          flex-direction: column;
          text-align: center;
        }

        .player-link {
          width: 100%;
          justify-content: center;
          flex-wrap: wrap;
        }

        .player-meta {
          flex-wrap: wrap;
          justify-content: center;
        }

        .hero,
        .search-panel,
        .team-card,
        .team-card-header,
        .team-card-header-main,
        .position-groups,
        .position-group-title {
          text-align: center;
        }

        .league-switcher {
          display: flex;
          justify-content: center;
        }

        .team-card-header-main {
          justify-content: center;
          width: 100%;
        }

        .team-card-header {
          flex-wrap: wrap;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <p class="eyebrow">Kickbase Liga Explorer</p>
        <h1>1. und 2. Bundesliga auf einen Blick</h1>
        <p class="hero-copy">
          Wähle oben die Liga aus und springe dann direkt zu Tabelle, Spieltagen, Top 10 und allen Teams dieser Liga.
        </p>

        <div class="league-switcher" role="tablist" aria-label="Liga auswahlen">
          {competitionSections.map((section, index) => (
            <button
              class:list={['league-switch-button', { active: index === 0 }]}
              type="button"
              data-competition-slug={section.slug}
            >
              {section.shortLabel}
            </button>
          ))}
        </div>

        {competitionSections.map((section, index) => (
          <div class:list={['competition-panel', 'quick-links', { active: index === 0 }]} data-competition-panel={section.slug}>
            <a class="quick-link" href={`${BASE_PATH_WITHOUT_DOMAIN}/${section.slug}/table`}>
              <span class="quick-link-title">{section.shortLabel} Tabelle</span>
              <span class="quick-link-copy">Aktuelle Platzierungen und Teamansicht</span>
            </a>
            <a class="quick-link" href={`${BASE_PATH_WITHOUT_DOMAIN}/${section.slug}/spieltag`}>
              <span class="quick-link-title">{section.shortLabel} Spieltage</span>
              <span class="quick-link-copy">Ergebnisse, Tore, Karten, Wechsel und Aufstellungen</span>
            </a>
            <a class="quick-link" href={`${BASE_PATH_WITHOUT_DOMAIN}/${section.slug}/top-players`}>
              <span class="quick-link-title">{section.shortLabel} Top 10</span>
              <span class="quick-link-copy">Spieltag und Gesamtwertung auf einer Seite</span>
            </a>
          </div>
        ))}

        <div class="search-panel" data-search-panel>
          <label class="search-label" for="player-search">Spieler suchen</label>
          <input
            id="player-search"
            class="search-input"
            type="search"
            placeholder="Name eingeben, z. B. Kane oder Musiala"
            autocomplete="off"
          />
          <div id="player-search-results" class="search-results"></div>
          <p id="player-search-empty" class="search-empty">Kein passender Spieler gefunden.</p>
        </div>
      </section>

      <section class="teams">
        {competitionSections.map((section, index) => (
          <section class:list={['teams-league-section', 'competition-panel', { active: index === 0 }]} data-competition-panel={section.slug}>
            <div class="teams-header">
              <h2>{section.shortLabel}</h2>
              <p>{section.playerCount} Spieler in der Übersicht</p>
            </div>

            <div class="team-grid">
              {section.groupedTeams.map(([team, players]: [string, PlayerListItem[]]) => (
                <article class="team-card">
                  <div class="team-card-header">
                    <div class="team-card-header-main">
                      <img
                        class="team-logo"
                        src={section.teamLogosByName[team]}
                        alt={`Logo von ${team}`}
                      />
                      <h3 class="team-card-title">{team}</h3>
                    </div>
                    <span class="player-count">{players.length} Spieler</span>
                  </div>

                  <div class="player-links">
                    <div class="position-groups">
                      {playerCategories.map(category => {
                        const playersInCategory = sortPlayers(players).filter(
                          (player: PlayerListItem) => player.position === category.position
                        );

                        if (playersInCategory.length === 0) {
                          return null;
                        }

                        return (
                          <section>
                            <h4 class="position-group-title">{category.label}</h4>
                            <div class="player-links">
                              {playersInCategory.map((player: PlayerListItem) => (
                                <a
                                  class="player-link"
                                  href={`${section.playerBasePath}/${encodeURIComponent(player.playerName)}/${encodeURIComponent(
                                    player.playerId
                                  )}`}
                                >
                                  <span>{player.playerName}</span>
                                  <span class="player-meta">
                                    {player.number ? <span class="player-number">#{player.number}</span> : null}
                                    {player.position ? (
                                      <span class="player-position">
                                        {getPlayerPositionLabel(player.position as unknown as PlayerPosition)}
                                      </span>
                                    ) : null}
                                  </span>
                                </a>
                              ))}
                            </div>
                          </section>
                        );
                      })}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </section>
    </main>
    <script define:vars={{ playerSearchData, BASE_PATH_WITHOUT_DOMAIN }}>
      const leagueButtons = Array.from(document.querySelectorAll('[data-competition-slug]'));
      const competitionPanels = Array.from(document.querySelectorAll('[data-competition-panel]'));
      const searchInput = document.getElementById('player-search');
      const searchResults = document.getElementById('player-search-results');
      const searchEmpty = document.getElementById('player-search-empty');
      let activeCompetitionSlug = 'bundesliga';

      const setActiveCompetition = slug => {
        activeCompetitionSlug = slug;

        leagueButtons.forEach(button => {
          button.classList.toggle('active', button.dataset.competitionSlug === slug);
        });

        competitionPanels.forEach(panel => {
          panel.classList.toggle('active', panel.dataset.competitionPanel === slug);
        });

        if (searchInput && searchInput.value.trim() !== '') {
          renderResults(searchInput.value);
        }
      };

      const normalizedPlayers = playerSearchData.map(player => ({
        ...player,
        competitionSlug:
          player.playerBasePath.includes('/zweite-bundesliga/') ? 'zweite-bundesliga' : 'bundesliga',
        searchValue: `${player.playerName} ${player.teamName} ${player.competitionLabel}`.toLowerCase()
      }));

      const renderResults = value => {
        if (!searchInput || !searchResults || !searchEmpty) {
          return;
        }

        const query = value.trim().toLowerCase();

        if (query === '') {
          searchResults.classList.remove('active');
          searchEmpty.classList.remove('active');
          searchResults.innerHTML = '';
          return;
        }

        const matches = normalizedPlayers
          .filter(player => player.competitionSlug === activeCompetitionSlug)
          .filter(player => player.searchValue.includes(query))
          .slice(0, 12);

        if (matches.length === 0) {
          searchResults.classList.remove('active');
          searchEmpty.classList.add('active');
          searchResults.innerHTML = '';
          return;
        }

        searchEmpty.classList.remove('active');
        searchResults.classList.add('active');
        searchResults.innerHTML = matches
          .map(player => {
            const href = `${player.playerBasePath}/${encodeURIComponent(player.playerName)}/${encodeURIComponent(player.playerId)}`;
            const detailParts = [player.teamName, player.competitionLabel];

            if (player.number) {
              detailParts.push(`#${player.number}`);
            }

            if (player.positionLabel) {
              detailParts.push(player.positionLabel);
            }

            return `
              <a class="search-result" href="${href}">
                <span class="search-result-line">
                  <span class="search-result-name">${player.playerName}</span>
                  <span class="search-result-meta"> · ${detailParts.join(' · ')}</span>
                </span>
              </a>
            `;
          })
          .join('');
      };

      if (searchInput && searchResults && searchEmpty) {
        leagueButtons.forEach(button => {
          button.addEventListener('click', () => {
            setActiveCompetition(button.dataset.competitionSlug);
          });
        });

        setActiveCompetition(activeCompetitionSlug);

        searchInput.addEventListener('input', event => {
          renderResults(event.target.value);
        });
      } else {
        leagueButtons.forEach(button => {
          button.addEventListener('click', () => {
            setActiveCompetition(button.dataset.competitionSlug);
          });
        });

        setActiveCompetition(activeCompetitionSlug);
      }
    </script>
  </body>
</html>
