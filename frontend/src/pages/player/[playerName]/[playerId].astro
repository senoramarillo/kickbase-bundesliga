---
import { BASE_PATH_WITHOUT_DOMAIN } from '../../../../base-path.mjs';
import { playerDataService, PlayerData } from '../../../services/playerdata/playerdata.service';
import { teamPlayerService } from '../../../services/team-players.service';
import { bundesligaTableService } from '../../../services/bundesliga-table.service';
import { BundesligaTableEntry, BundesligaTable } from '../../../models/bundesliga-table';
import { PlayerListItem } from '../../../models/player-list-item';
import favIcon from '../../../../images/favicon-16.png';
import noProfilePicFallback from '../../../../images/no_profile_pic.png';
import '../../../styles/page.css';
import { PlayerPage } from '../../../components/player.page';

const { params } = Astro;
const serverJsonData: PlayerData = await playerDataService.getData(String(params.playerId));

export async function getStaticPaths() {
  const bundesligaTable: BundesligaTable = await bundesligaTableService.getData();
  const teamIds: string[] = bundesligaTable.teams.map((team: BundesligaTableEntry) => team.teamId);
  const deepPlayerData: { params: any; metadata: PlayerListItem }[][] = [];

  for (const teamId of teamIds) {
    const result = await teamPlayerService.getBasicData(teamId);
    deepPlayerData.push(
      result.map(player => {
        return {
          params: {
            playerName: `${player.playerName}`,
            playerId: String(player.playerId)
          },
          metadata: {
            ...player
          }
        };
      })
    );
  }

  return deepPlayerData.flat();
}

const playerName: string = String(serverJsonData?.playerInfo?.knownName ?? params.playerName);
const season2526 = serverJsonData.playerPoints.seasons.find(season => season.year === '2025/2026');
const props = {
  'player-name': playerName,
  'player-id': params.playerId,
  'team-id': serverJsonData.playerInfo.teamId,
  'server-json-data': JSON.stringify(serverJsonData)
};
---

<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <link rel='preload' as='image' href={serverJsonData.playerInfo.profileBig || noProfilePicFallback} />
    <link rel='preload' as='font' href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-700.woff2`} />
    <link rel='preload' as='font' href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-regular.woff2`} />
    <link rel='icon' type='image/x-icon' href={favIcon} />
    <title>{playerName}</title>
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='description' content={`Spielerprofil von ${playerName} - kickbase-bundesliga`} />
  </head>
  <body style='padding:0 !important;'>
    <PlayerPage {...props} client:idle />
    {
      season2526 ? (
        <pre style='white-space: pre-wrap; padding: 1rem; background: #fff; border-top: 1px solid #ddd; font-size: 12px;'>
{JSON.stringify(
  {
    year: season2526.year,
    matchesLength: season2526.matches.length,
    firstMatches: season2526.matches.slice(0, 5),
    lastMatches: season2526.matches.slice(-5)
  },
  null,
  2
)}
        </pre>
      ) : null
    }
    <script is:inline>
      const scrollPlayerPointsToCurrentMatchday = () => {
        const playerRoot = document.querySelector('bkb-player');
        const pointsRoot = playerRoot?.shadowRoot?.querySelector('bkb-player-points');
        const scroller = pointsRoot?.shadowRoot?.querySelector('.root');

        if (!(scroller instanceof HTMLElement)) {
          return false;
        }

        const nextScrollLeft = Math.max(0, scroller.scrollWidth - scroller.clientWidth);
        if (nextScrollLeft <= 0) {
          return false;
        }

        scroller.scrollLeft = nextScrollLeft;
        return Math.abs(scroller.scrollLeft - nextScrollLeft) < 2;
      };

      const schedulePlayerPointsScroll = () => {
        [0, 80, 180, 350, 700, 1200, 2000].forEach(delay => {
          window.setTimeout(() => {
            requestAnimationFrame(() => {
              scrollPlayerPointsToCurrentMatchday();
            });
          }, delay);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', schedulePlayerPointsScroll, { once: true });
      } else {
        schedulePlayerPointsScroll();
      }

      window.addEventListener('astro:hydrate', schedulePlayerPointsScroll);
      window.addEventListener('load', schedulePlayerPointsScroll, { once: true });
    </script>
  </body>
</html>
