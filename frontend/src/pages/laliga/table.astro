---
import favIcon from '../../../images/favicon-16.png';
import { laLigaTableService } from '../../services/laliga-table.service';
import { LaLigaTable } from '../../models/laliga-table';
import { BASE_PATH_WITHOUT_DOMAIN, COMPETITION_CONFIG } from '../../../base-path.mjs';
import '../../components/laliga-table.page';
import '../../styles/page.css';
import { LaLigaTablePage } from '../../components/laliga-table.page';

const laLigaTable: LaLigaTable = await laLigaTableService.getData();
const props: Record<string, string> = {
  'server-json-data': JSON.stringify(laLigaTable)
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={favIcon} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-700.woff2`} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-regular.woff2`} />
    <title>{COMPETITION_CONFIG.competitionName} Tabelle</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${COMPETITION_CONFIG.siteName} ${COMPETITION_CONFIG.competitionName} Tabelle`} />
  </head>
  <body style="background-color: #e8edf1;  padding: 1rem;">
    <LaLigaTablePage {...props} client:idle />
  </body>
</html>
