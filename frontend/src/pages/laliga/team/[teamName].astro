---
import { BASE_PATH_WITHOUT_DOMAIN, COMPETITION_CONFIG } from '../../../../base-path.mjs';
import favIcon from '../../../../images/favicon-16.png';
import '../../../styles/page.css';
import { teamPlayerService } from '../../../services/team-players.service';
import { laLigaTableService } from '../../../services/laliga-table.service';
import { LaLigaTableEntry, LaLigaTable } from '../../../models/laliga-table';
import { PlayerListItem } from '../../../models/player-list-item';
import '../../../components/laliga-team.page';
import { LaLigaTeamPage } from '../../../components/laliga-team.page';
const { params } = Astro;

export async function getStaticPaths() {
  const laLigaTable: LaLigaTable = await laLigaTableService.getData();
  const teams: { params: { teamName: string } }[] = laLigaTable.teams.map((team: LaLigaTableEntry) => {
    return { params: { teamName: team.teamName } };
  });
  return teams;
}

const currentTable: LaLigaTable = await laLigaTableService.getData();
const currentTeam = currentTable.teams.find(team => team.teamName === params.teamName);
const teamId: string = currentTeam?.teamId ?? '';
const serverJsonData: PlayerListItem[] = await teamPlayerService.getData(String(teamId));

const props = {
  'team-name': params.teamName,
  'team-id': String(teamId),
  'server-json-data': JSON.stringify(serverJsonData)
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-700.woff2`} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-regular.woff2`} />
    <link rel="icon" type="image/x-icon" href={favIcon} />
    <title>{params.teamName}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${params.teamName} - ${COMPETITION_CONFIG.siteName}`} />
  </head>
  <body style="background-color: #e8edf1;  padding: 1rem;">
    <LaLigaTeamPage {...props} client:idle />
  </body>
</html>
