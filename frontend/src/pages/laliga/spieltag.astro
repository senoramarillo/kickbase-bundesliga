---
import favIcon from '../../../images/favicon-16.png';
import { BASE_PATH_WITHOUT_DOMAIN, COMPETITION_CONFIG } from '../../../base-path.mjs';
import { matchdaysService, MatchdayOverview } from '../../services/matchdays.service';
import '../../components/matchdays.page';
import '../../styles/page.css';
import { MatchdaysPage } from '../../components/matchdays.page';

const matchdayOverview: MatchdayOverview = await matchdaysService.getData();
const props: Record<string, string> = {
  'server-json-data': JSON.stringify(matchdayOverview)
};
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={favIcon} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-700.woff2`} />
    <link rel="preload" as="font" href={`${BASE_PATH_WITHOUT_DOMAIN}/fonts/roboto-condensed-v24-latin-regular.woff2`} />
    <title>{COMPETITION_CONFIG.competitionName} Spieltag</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={`${COMPETITION_CONFIG.siteName} Spieltagsübersicht mit Partien und Ergebnissen`}
    />
  </head>
  <body style="background-color: #e8edf1; padding: 1rem;">
    <MatchdaysPage {...props} client:idle />
  </body>
</html>
